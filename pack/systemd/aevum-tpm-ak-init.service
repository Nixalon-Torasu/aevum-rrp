[Unit]
Description=Aevum TPM Attestation Key (AK) Init
After=local-fs.target
Wants=local-fs.target

[Service]
Type=oneshot
ExecStart=/opt/aevum-tools/bin/aevum-tpm-ak-init --instance workstation

# --- Aevum service hardening (control-plane, non-gating) ---
NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
LockPersonality=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
SystemCallArchitectures=native
UMask=0077

