[Unit]
Description=Aevum TPM Receipt Signing Policy Sync (receipt and stable pointers)
After=local-fs.target
Wants=local-fs.target

[Service]
Type=oneshot
ExecStart=/opt/aevum-tools/bin/aevum-tpm-receipt-policy sync

NoNewPrivileges=yes
PrivateTmp=yes
ProtectHome=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
LockPersonality=yes
RestrictSUIDSGID=yes
RestrictRealtime=yes
SystemCallArchitectures=native
UMask=0077
