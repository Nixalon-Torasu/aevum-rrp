#!/usr/bin/env bash
set -euo pipefail

# aevum-egress-profile-run
#
# Declarative egress windows by named profile.
#
# Usage:
#   aevum-egress-profile-run <profile> <seconds> -- <command...>
#
# Profiles live at:
#   /etc/aevum/egress_profiles.d/<profile>.conf
#
# Profile files are shell snippets that can set:
#   EGRESS_CONTAINER_MODE=any|allowlist
#   EGRESS_ALLOW_LABELS="label ..."
#   EGRESS_DEST_MODE=any|allowlist
#   EGRESS_ALLOW_DOMAINS="domain ..."
#   EGRESS_ALLOW_DST_V4="ip/cidr ..."
#   EGRESS_ALLOW_DST_V6="ip/cidr ..."
#   EGRESS_DNS_MODE=any|allowlist
#   EGRESS_DNS_SERVERS_V4="ip ..."
#   EGRESS_DNS_SERVERS_V6="ip ..."
#
# This tool creates a short-lived overlay:
#   /etc/aevum/egressctl.d/90-runtime-profile.conf
# then runs aevum-egressctl run ... and removes the overlay afterward.
#
# Rationale:
# - Avoid global overlays that affect unrelated egress windows.
# - Make egress intent explicit and receiptable.

PROFILE="${1:-}"
SECONDS="${2:-}"
shift || true
shift || true

if [[ -z "${PROFILE}" || -z "${SECONDS}" || "${1:-}" != "--" ]]; then
  echo "Usage: aevum-egress-profile-run <profile> <seconds> -- <command...>" >&2
  exit 2
fi
shift

PROFILES_DIR="/etc/aevum/egress_profiles.d"
PROFILE_FILE="${PROFILES_DIR}/${PROFILE}.conf"
OVERLAY_DIR="/etc/aevum/egressctl.d"
OVERLAY_FILE="${OVERLAY_DIR}/90-runtime-profile.conf"

if [[ ! -f "${PROFILE_FILE}" ]]; then
  echo "ERROR: profile not found: ${PROFILE_FILE}" >&2
  exit 3
fi

mkdir -p "${OVERLAY_DIR}"

# Load base config so profile can reference it if desired.
BASECONF="/etc/aevum/egressctl.conf"
[[ -f "${BASECONF}" ]] && source "${BASECONF}"

# shellcheck disable=SC1090
source "${PROFILE_FILE}"

# Write runtime overlay with the vars we care about (only those set).
{
  echo "# Runtime overlay generated by aevum-egress-profile-run"
  echo "# profile=${PROFILE}"
  [[ -n "${EGRESS_CONTAINER_MODE:-}" ]] && echo "EGRESS_CONTAINER_MODE=${EGRESS_CONTAINER_MODE}"
  [[ -n "${EGRESS_ALLOW_LABELS:-}" ]] && echo "EGRESS_ALLOW_LABELS=\"${EGRESS_ALLOW_LABELS}\""
  [[ -n "${EGRESS_DEST_MODE:-}" ]] && echo "EGRESS_DEST_MODE=${EGRESS_DEST_MODE}"
  [[ -n "${EGRESS_ALLOW_DOMAINS:-}" ]] && echo "EGRESS_ALLOW_DOMAINS=\"${EGRESS_ALLOW_DOMAINS}\""
  [[ -n "${EGRESS_ALLOW_DST_V4:-}" ]] && echo "EGRESS_ALLOW_DST_V4=\"${EGRESS_ALLOW_DST_V4}\""
  [[ -n "${EGRESS_ALLOW_DST_V6:-}" ]] && echo "EGRESS_ALLOW_DST_V6=\"${EGRESS_ALLOW_DST_V6}\""
  [[ -n "${EGRESS_DNS_MODE:-}" ]] && echo "EGRESS_DNS_MODE=${EGRESS_DNS_MODE}"
  [[ -n "${EGRESS_DNS_SERVERS_V4:-}" ]] && echo "EGRESS_DNS_SERVERS_V4=\"${EGRESS_DNS_SERVERS_V4}\""
  [[ -n "${EGRESS_DNS_SERVERS_V6:-}" ]] && echo "EGRESS_DNS_SERVERS_V6=\"${EGRESS_DNS_SERVERS_V6}\""
  [[ -n "${EGRESS_OBSERVE:-}" ]] && echo "EGRESS_OBSERVE=${EGRESS_OBSERVE}"
} > "${OVERLAY_FILE}"

OVERLAY_HASH="$(sha256sum "${OVERLAY_FILE}" | awk '{print $1}')"

cleanup() {
  rm -f "${OVERLAY_FILE}" || true
  # Best-effort refresh sets back to base config (now that overlay is gone).
  /opt/aevum-tools/bin/aevum-egress-dst-refresh >/dev/null 2>&1 || true
  /opt/aevum-tools/bin/aevum-egress-dns-refresh >/dev/null 2>&1 || true
}
trap cleanup EXIT

# Populate sets for allowlist modes.
/opt/aevum-tools/bin/aevum-egress-dst-refresh >/dev/null 2>&1 || true
/opt/aevum-tools/bin/aevum-egress-dns-refresh >/dev/null 2>&1 || true
/opt/aevum-tools/bin/aevum-egress-allowlist-refresh >/dev/null 2>&1 || true

# Receipt the declared intent.
if [[ -x /opt/aevum-tools/bin/aevum-receipt ]]; then
  /opt/aevum-tools/bin/aevum-receipt note "egress profile run" component=egress profile="${PROFILE}" overlay="sha256:${OVERLAY_HASH}" seconds="${SECONDS}" || true
fi

exec /opt/aevum-tools/bin/aevum-egressctl run "${SECONDS}" -- "$@"
