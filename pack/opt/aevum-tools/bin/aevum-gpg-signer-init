#!/usr/bin/env bash
set -euo pipefail

# aevum-gpg-signer-init (v0.1)
# Creates a LOCAL GPG signing key used to sign:
# - registry policy files (/etc/aevum/registry/*)
# - bootstrap manifest hashes (/etc/aevum/bootstrap_manifest.sha256)
# - GitOps tags/commits (optional; repo-side)
#
# This key is root-owned, local-first. You can replace it with an offline signer later.
#
# Outputs:
#   /var/lib/aevum/workstation/keys/gpg_signing   (GNUPGHOME for signing)
#   /etc/aevum/trustedkeys.d/aevum-workstation-signer.asc  (public key allowlist)
#   Updates verification keyring: /etc/aevum/gnupg
#
# Non-gating: If gpg missing, exits 0 (bootstrap still works), but signing won't happen.

GNUPGHOME_SIGN="${GNUPGHOME_SIGN:-/var/lib/aevum/workstation/keys/gpg_signing}"
KEYSDIR="${KEYSDIR:-/etc/aevum/trustedkeys.d}"
VERIFY_HOME="${VERIFY_HOME:-/etc/aevum/gnupg}"
UID="${UID_STRING:-Aevum Workstation Signer (local) <aevum@localhost>}"

[[ "$(id -u)" -eq 0 ]] || { echo "Run as root." >&2; exit 2; }
command -v gpg >/dev/null 2>&1 || { echo "INFO: gpg missing; skipping signer init."; exit 0; }

mkdir -p "${GNUPGHOME_SIGN}" "${KEYSDIR}" "${VERIFY_HOME}"
chmod 0700 "${GNUPGHOME_SIGN}" "${VERIFY_HOME}" || true
chmod 0755 "${KEYSDIR}" || true

# If a secret key already exists, reuse it
if gpg --homedir "${GNUPGHOME_SIGN}" --list-secret-keys >/dev/null 2>&1; then
  :
else
  gpg --homedir "${GNUPGHOME_SIGN}" --batch --pinentry-mode loopback --passphrase ""     --quick-gen-key "${UID}" ed25519 sign 0 >/dev/null 2>&1 || true
fi

# Pick first secret key fingerprint
FPR="$(gpg --homedir "${GNUPGHOME_SIGN}" --list-secret-keys --with-colons 2>/dev/null | awk -F: '/^fpr:/{print $10; exit}')"
[[ -n "${FPR}" ]] || { echo "WARN: unable to create/find signing key"; exit 0; }

PUB="${KEYSDIR}/aevum-workstation-signer.asc"
gpg --homedir "${GNUPGHOME_SIGN}" --armor --export "${FPR}" > "${PUB}" 2>/dev/null || true
chmod 0644 "${PUB}" || true

# Import pubkey into verification ring
if [[ -x /opt/aevum-tools/bin/aevum-gpgctl ]]; then
  /opt/aevum-tools/bin/aevum-gpgctl init >/dev/null 2>&1 || true
  /opt/aevum-tools/bin/aevum-gpgctl import-dir >/dev/null 2>&1 || true
else
  gpg --homedir "${VERIFY_HOME}" --batch --quiet --import "${PUB}" >/dev/null 2>&1 || true
fi

# Configure controlplane repo to sign by default (best-effort)
if [[ -d /opt/aevum-controlplane/.git ]]; then
  git -C /opt/aevum-controlplane config user.signingkey "${FPR}" || true
  git -C /opt/aevum-controlplane config commit.gpgsign true || true
  git -C /opt/aevum-controlplane config tag.gpgsign true || true
fi

if [[ -x /opt/aevum-tools/bin/aevum-receipt ]]; then
  /opt/aevum-tools/bin/aevum-receipt note "gpg signer initialized" component=gpg fpr="${FPR}" pub="${PUB}" || true
fi

echo "OK: signer fpr=${FPR} pub=${PUB} home=${GNUPGHOME_SIGN}"
