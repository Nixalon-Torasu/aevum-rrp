#!/usr/bin/env bash
set -euo pipefail
# Aevum receipt compatibility wrapper for controlplane scripts.
# Maps: aevum-receipt <kind> "<message>" [key=value ...]
# into an Aevum Interaction-chain (I) receipt (non-governing).
#
# NOTE: This does NOT replicate the legacy /var/lib/aevum/ledger leaf-signature system.
# It writes to /var/lib/aevum/workstation receipts via aevum_receiptctl.py.

if [[ $# -lt 2 ]]; then
  echo "Usage: aevum-receipt <kind> \"<message>\" [key=value ...]" >&2
  exit 2
fi

KIND="$1"; shift
MSG="$1"; shift

exec /usr/local/sbin/aevum_receiptctl.py \
  --base /var/lib/aevum/workstation \
  --kind "$KIND" \
  --message "$MSG" \
  "$@"
