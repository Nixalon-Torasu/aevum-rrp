#!/usr/bin/env bash
# AEVUM_FIX_PY_HEREDOC_TERMINATORS_V1
set -euo pipefail
# aevum-registry-sign (v0.1)
# Signs /etc/aevum/registry policy files with the LOCAL signer key.
#
# Produces detached ASCII signatures: <file>.asc
# Writes: /etc/aevum/registry/SIGNATURE_MANIFEST.json
#
# Non-gating: if signing key is absent, exits 0.

REG="/etc/aevum/registry"
GNUPGHOME_SIGN="${GNUPGHOME_SIGN:-/var/lib/aevum/workstation/keys/gpg_signing}"
UID_FPR="${FPR:-}"

[[ "$(id -u)" -eq 0 ]] || { echo "Run as root." >&2; exit 2; }
command -v gpg >/dev/null 2>&1 || { echo "INFO: gpg missing; skip"; exit 0; }
[[ -d "${REG}" ]] || { echo "INFO: registry missing; skip"; exit 0; }
mkdir -p "${GNUPGHOME_SIGN}"; chmod 0700 "${GNUPGHOME_SIGN}" || true

if [[ -z "${UID_FPR}" ]]; then
  UID_FPR="$(gpg --homedir "${GNUPGHOME_SIGN}" --list-secret-keys --with-colons 2>/dev/null | awk -F: '/^fpr:/{print $10; exit}')"
fi
[[ -n "${UID_FPR}" ]] || { echo "INFO: no signer key; run aevum-gpg-signer-init"; exit 0; }

tmp="$(mktemp)"
python3 - <<'PY' > "${tmp}"
import json, os, glob, hashlib, time
REG=os.environ.get("REG","/etc/aevum/registry")
files=[]
for root,dirs,fn in os.walk(REG):
    for f in fn:
        if f.endswith(".asc") or f=="SIGNATURE_MANIFEST.json":
            continue
        if f.startswith("."):
            continue
        p=os.path.join(root,f)
        if os.path.isfile(p):
            files.append(p)
files.sort()
def sha(p):
    return hashlib.sha256(open(p,'rb').read()).hexdigest()
obj={"type":"aevum_registry_signature_manifest_v1","generated_at":time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),"files":[]}
for p in files:
    obj["files"].append({"path":p,"sha256":"sha256:"+sha(p)})
print(json.dumps(obj, indent=2, sort_keys=True))
PY

# Sign each file
while read -r f; do
  [[ -f "$f" ]] || continue
  sig="${f}.asc"
  gpg --homedir "${GNUPGHOME_SIGN}" --batch --yes --pinentry-mode loopback --passphrase ""     --local-user "${UID_FPR}" --armor --detach-sign -o "${sig}" "${f}" >/dev/null 2>&1 || true
  chmod 0644 "${sig}" || true
done < <(python3 - <<'PY'
import os
REG="/etc/aevum/registry"
for root,dirs,fn in os.walk(REG):
    for f in sorted(fn):
        if f.endswith(".asc") or f=="SIGNATURE_MANIFEST.json" or f.startswith("."):
            continue
        p=os.path.join(root,f)
        if os.path.isfile(p):
            print(p)
PY
)

# Update manifest with signature hashes
python3 - <<'PY'
import os, json, hashlib, time
REG="/etc/aevum/registry"
def sha(p): return hashlib.sha256(open(p,'rb').read()).hexdigest()
mf=os.path.join(REG,"SIGNATURE_MANIFEST.json")
obj={"type":"aevum_registry_signature_manifest_v1","generated_at":time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),"signer":{},"files":[]}
# signer info best-effort
obj["signer"]["gnupghome"]=os.environ.get("GNUPGHOME_SIGN","")
obj["signer"]["fpr"]=os.environ.get("UID_FPR","")
files=[]
for root,dirs,fn in os.walk(REG):
    for f in fn:
        if f.endswith(".asc") or f=="SIGNATURE_MANIFEST.json" or f.startswith("."):
            continue
        p=os.path.join(root,f)
        if os.path.isfile(p):
            sig=p+".asc"
            obj["files"].append({"path":p,"sha256":"sha256:"+sha(p),"sig_path":sig,"sig_sha256":"sha256:"+sha(sig) if os.path.isfile(sig) else ""})
obj["files"].sort(key=lambda x:x["path"])
open(mf,'w',encoding='utf-8').write(json.dumps(obj, indent=2, sort_keys=True)+"\n")
PY
chmod 0644 "${REG}/SIGNATURE_MANIFEST.json" || true

if [[ -x /opt/aevum-tools/bin/aevum-receipt ]]; then
  h="$(sha256sum "${REG}/SIGNATURE_MANIFEST.json" | awk '{print $1}')"
  /opt/aevum-tools/bin/aevum-receipt note "registry signed" component=gpg manifest="sha256:${h}" reg="${REG}" || true
fi

echo "OK: signed registry; manifest=${REG}/SIGNATURE_MANIFEST.json"
