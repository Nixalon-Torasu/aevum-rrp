#!/usr/bin/env bash
set -euo pipefail

MODE="${1:-}"
if [[ "${MODE}" != "--measure-only" ]]; then
  echo "Usage: aevum-ima-enable --measure-only" >&2
  exit 2
fi

CFG="/etc/default/grub.d/99-aevum-ima.cfg"
PARAMS="ima_tcb ima_hash=sha256"

sudo mkdir -p /etc/default/grub.d
echo "GRUB_CMDLINE_LINUX_DEFAULT=\"${PARAMS} \${GRUB_CMDLINE_LINUX_DEFAULT:-}\"" | sudo tee "${CFG}" >/dev/null

echo "Wrote: ${CFG}"
echo "Updating grub..."
sudo update-grub

echo "OK. Reboot required for kernel cmdline to take effect."
echo "After reboot: aevum-ima-status"
