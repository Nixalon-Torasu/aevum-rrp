#!/usr/bin/env bash
set -euo pipefail

# aevum-release-key-rotate (bootkit/operator)
# Manual trust root rotation: operator supplies a new Ed25519 public key (raw 32 bytes, base64).
# NO key generation occurs on-box.

PUBKEY_FILE="/etc/aevum/trust/release_pubkey.ed25519.b64"
TRUST_EPOCH_FILE="/etc/aevum/trust/trust_epoch.json"

OPDIR="/var/lib/aevum/operator"
ACTIONS_LOG="${OPDIR}/actions.jsonl"
EVID_EPOCH_FILE="${OPDIR}/evidence_epoch.json"
ID_EPOCH_FILE="${OPDIR}/identity_epoch.json"

NEW_B64=""
NEW_FILE=""

usage() {
  echo "Usage:"
  echo "  sudo aevum-release-key-rotate --new-pubkey-b64 <B64>"
  echo "  sudo aevum-release-key-rotate --new-pubkey-file <path>"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --new-pubkey-b64) NEW_B64="${2:-}"; shift 2;;
    --new-pubkey-file) NEW_FILE="${2:-}"; shift 2;;
    -h|--help) usage; exit 0;;
    *) echo "ERROR: unknown arg: $1"; usage; exit 2;;
  esac
done

if [[ -z "$NEW_B64" && -n "$NEW_FILE" ]]; then
  NEW_B64="$(tr -d ' \t\r\n' < "$NEW_FILE" || true)"
fi

if [[ -z "$NEW_B64" ]]; then
  echo "ERROR: missing new pubkey" >&2
  usage
  exit 2
fi

# Confirm (hard)
echo -n "ROTATE RELEASE KEY? This immediately invalidates bundles signed by the previous key. Type YES to continue: "
read -r CONFIRM || true
if [[ "$CONFIRM" != "YES" ]]; then
  echo "Aborted (no-op)."
  exit 0
fi

# Ensure dirs
sudo install -d -m 0700 "$OPDIR" >/dev/null 2>&1 || true
sudo install -d -m 0755 /etc/aevum >/dev/null 2>&1 || true
sudo install -d -m 0755 /etc/aevum/trust >/dev/null 2>&1 || true

TS_UTC="$(date -u +%Y-%m-%dT%H%M%SZ)"

# Validate base64 decodes to exactly 32 bytes and compute key ids
read -r OLD_KEY_ID NEW_KEY_ID NEW_B64_NORM < <(python3 - <<'PY' "$PUBKEY_FILE" "$NEW_B64"
import base64,hashlib,sys,os
pubf=sys.argv[1]; newb64=sys.argv[2]
def key_id(raw): return "sha256:"+hashlib.sha256(raw).hexdigest()

old_id="sha256:" + "0"*64
if os.path.exists(pubf):
    try:
        old_raw=base64.b64decode(open(pubf,"rb").read().strip(), validate=True)
        if len(old_raw)==32:
            old_id=key_id(old_raw)
    except Exception:
        pass

try:
    new_raw=base64.b64decode(newb64.encode("ascii"), validate=True)
except Exception as e:
    print(old_id, "INVALID", "")
    sys.exit(3)
if len(new_raw)!=32:
    print(old_id, "INVALID", "")
    sys.exit(3)
print(old_id, key_id(new_raw), base64.b64encode(new_raw).decode("ascii"))
PY
) || { echo "ERROR: invalid pubkey base64 (must decode to 32 bytes)" >&2; exit 2; }

if [[ "$NEW_KEY_ID" == "INVALID" ]]; then
  echo "ERROR: invalid pubkey base64 (must decode to 32 bytes)" >&2
  exit 2
fi

# Read current epochs (best-effort)
read -r TE EE IE < <(python3 - <<'PY' "$TRUST_EPOCH_FILE" "$EVID_EPOCH_FILE" "$ID_EPOCH_FILE"
import json,sys,os
def read_epoch(p):
    if not os.path.exists(p): return 0
    try:
        d=json.load(open(p,"r",encoding="utf-8"))
        return int(d.get("epoch",0))
    except Exception:
        return 0
print(read_epoch(sys.argv[1]), read_epoch(sys.argv[2]), read_epoch(sys.argv[3]))
PY
)

NEW_TE=$((TE+1))

# Atomic write pubkey
tmp="$(mktemp /tmp/aevum_release_pubkey.XXXXXX)"
printf "%s\n" "$NEW_B64_NORM" > "$tmp"
sudo install -m 0644 "$tmp" "$PUBKEY_FILE"
rm -f "$tmp"

# Write trust epoch
tmpj="$(mktemp /tmp/aevum_trust_epoch.XXXXXX)"
python3 - <<'PY' "$tmpj" "$NEW_TE" "$TS_UTC" "$NEW_KEY_ID" "$NEW_B64_NORM"
import json,sys
p=sys.argv[1]
out={
  "epoch_kind":"trust",
  "epoch": int(sys.argv[2]),
  "updated_utc": sys.argv[3],
  "key_id": sys.argv[4],
  "pubkey_b64": sys.argv[5],
}
open(p,"w",encoding="utf-8").write(json.dumps(out, indent=2)+"\n")
PY
sudo install -m 0644 "$tmpj" "$TRUST_EPOCH_FILE"
rm -f "$tmpj"

# Append operator record (durable best-effort)
python3 - <<'PY' "$ACTIONS_LOG" "$TS_UTC" "$TE" "$EE" "$IE" "$NEW_TE" "$OLD_KEY_ID" "$NEW_KEY_ID" "$NEW_B64_NORM"
import json,os,sys,datetime
log=sys.argv[1]
ts=sys.argv[2]
te=int(sys.argv[3]); ee=int(sys.argv[4]); ie=int(sys.argv[5])
new_te=int(sys.argv[6])
old_id=sys.argv[7]; new_id=sys.argv[8]; new_b64=sys.argv[9]
sudo_user=os.environ.get("SUDO_USER") or os.environ.get("USER") or "unknown"
uid=os.getuid()
rec={
  "ts_utc": ts,
  "action_kind": "release_key_rotate",
  "actor": {"sudo_user": sudo_user, "uid": uid},
  "pre_state": {"trust_epoch": te, "evidence_epoch": ee, "identity_epoch": ie, "release_key_id": old_id},
  "post_state": {"trust_epoch": new_te, "evidence_epoch": ee, "identity_epoch": ie, "release_key_id": new_id},
  "outcome": "ok",
  "details": {
    "bounded_reason": "operator_initiated",
    "old_release_key_id": old_id,
    "new_release_key_id": new_id,
    "new_pubkey_b64": new_b64
  }
}
os.makedirs(os.path.dirname(log), exist_ok=True)
with open(log,"a",encoding="utf-8") as f:
    f.write(json.dumps(rec, separators=(",",":"))+"\n")
    f.flush()
    os.fsync(f.fileno())
PY

echo "OK: rotated release key"
echo "  old: $OLD_KEY_ID"
echo "  new: $NEW_KEY_ID"
echo "  trust_epoch: $NEW_TE"
