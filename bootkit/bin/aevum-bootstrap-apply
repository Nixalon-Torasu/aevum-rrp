#!/usr/bin/env bash
set -euo pipefail

MODE_FILE="/etc/aevum/mode"
MODE="${AEVUM_MODE:-}"
if [ -z "$MODE" ]; then
  if [ -f "$MODE_FILE" ]; then
    MODE="$(tr -d ' \t\r\n' < "$MODE_FILE" || true)"
  fi
fi
MODE="${MODE:-install}"

FWMODE="install"
if [ "$MODE" = "locked" ]; then FWMODE="locked"; fi

BASE="/srv/aevum-hot/bootstrap"
STAGE="$BASE/stage"
CURRENT="$BASE/current"
CUR_BUNDLE=""
if [ -L "$STAGE/current" ]; then
  CUR_BUNDLE="$(readlink -f "$STAGE/current" || true)"
elif [ -f "$STAGE/CURRENT_BUNDLE" ]; then
  CUR_BUNDLE="$(cat "$STAGE/CURRENT_BUNDLE" 2>/dev/null || true)"
fi

if [ -z "$CUR_BUNDLE" ]; then
  echo "ERROR: No staged bundle found. Run: sudo aevum-bootstrap-update"
  exit 1
fi

MAN="$CUR_BUNDLE/BUNDLE_MANIFEST.json"
if [ ! -f "$MAN" ]; then
  echo "ERROR: Staged bundle missing BUNDLE_MANIFEST.json: $MAN"
  exit 2
fi

echo "== AEVUM BOOTSTRAP APPLY =="
echo "Mode:     $MODE"
echo "Bundle:   $CUR_BUNDLE"
echo "Manifest: $MAN"

if [ "$MODE" = "estop" ]; then
  echo "ERROR: Mode is estop; refusing to apply."
  exit 3
fi

# In locked mode, require signed pack manifests (Ed25519 over PACK_MANIFEST.sha256)
# pubkey: /etc/aevum/trust/release_pubkey.ed25519.b64

get_field() {
  python3 - <<'PY' "$1" "$2"
import json,sys
p=sys.argv[1]; key=sys.argv[2]
with open(p,"r",encoding="utf-8") as f: d=json.load(f)
cur=d
for part in key.split("."):
  cur=cur[part]
print(cur)
PY
}

sha_check() {
  local rel="$1" expected="$2"
  local fp="$CUR_BUNDLE/$rel"
  if [ ! -f "$fp" ]; then
    echo "ERROR: Missing staged file: $fp"
    exit 5
  fi
  local actual
  actual="$(sha256sum "$fp" | awk '{print $1}')"
  if [ "$actual" != "$expected" ]; then
    echo "ERROR: sha256 mismatch for $rel"
    echo "  expected: $expected"
    echo "  actual:   $actual"
    exit 6
  fi
}

verify_pack_sig() {
  local manifest="$1" sig="$2"
  local pub="/etc/aevum/trust/release_pubkey.ed25519.b64"
  if [[ "$MODE" != "locked" ]]; then return 0; fi
  if [[ ! -f "$pub" ]]; then
    echo "ERROR: locked mode requires pubkey at $pub" >&2
    exit 4
  fi
  if [[ ! -f "$manifest" || ! -f "$sig" ]]; then
    echo "ERROR: locked mode requires $manifest and $sig" >&2
    exit 4
  fi
  python3 - <<'PY' "$pub" "$manifest" "$sig"
import base64,sys
pubf,manf,sigf=sys.argv[1:4]
try:
    from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PublicKey
except Exception:
    print("ERROR: cryptography missing for locked-mode signature verification", file=sys.stderr)
    sys.exit(2)
pub=base64.b64decode(open(pubf,'rb').read().strip(), validate=True)
sig=base64.b64decode(open(sigf,'rb').read().strip(), validate=True)
man=open(manf,'rb').read()
Ed25519PublicKey.from_public_bytes(pub).verify(sig, man)
print("OK: signature verified:", manf)
PY
}


sha_check "$(get_field "$MAN" "artifacts.bootkit.zip")"   "$(get_field "$MAN" "artifacts.bootkit.sha256")"
sha_check "$(get_field "$MAN" "artifacts.bootstrap.zip")" "$(get_field "$MAN" "artifacts.bootstrap.sha256")"
sha_check "$(get_field "$MAN" "artifacts.gitops.zip")"    "$(get_field "$MAN" "artifacts.gitops.sha256")"
echo "[verify] Zip sha256 checks OK."

# Verify bootkit manifest
BOOTKIT_ROOT="$(get_field "$MAN" "artifacts.bootkit.root")"
if [ -f "$BOOTKIT_ROOT/PACK_MANIFEST.sha256" ]; then
  echo "[verify] bootkit pack manifest..."
  ( cd "$BOOTKIT_ROOT" && sha256sum -c PACK_MANIFEST.sha256 )
else
  echo "ERROR: bootkit missing PACK_MANIFEST.sha256"
  exit 7
fi

# Verify internal pack manifests again (cheap + safe)
BOOT_ROOT="$(get_field "$MAN" "artifacts.bootstrap.root")"
GITOPS_ROOT="$(get_field "$MAN" "artifacts.gitops.root")"

if [ -f "$BOOT_ROOT/pack/PACK_MANIFEST.sha256" ]; then
  echo "[verify] bootstrap pack manifest..."
  ( cd "$BOOT_ROOT/pack" && sha256sum -c PACK_MANIFEST.sha256 )
else
  echo "ERROR: bootstrap pack missing PACK_MANIFEST.sha256"
  exit 8
fi
if [ -f "$GITOPS_ROOT/PACK_MANIFEST.sha256" ]; then
  echo "[verify] gitops pack manifest..."
  ( cd "$GITOPS_ROOT" && sha256sum -c PACK_MANIFEST.sha256 )
else
  echo "ERROR: gitops pack missing PACK_MANIFEST.sha256"
  exit 9
fi

# ---------------------------------------------------------------
# OpenSSF provenance verification (before any apply step)
# ---------------------------------------------------------------
echo "[provenance] Running supply-chain verification..."
PROV_VERIFY="$(command -v aevum-provenance-verify 2>/dev/null || echo "")"
if [ -z "$PROV_VERIFY" ]; then
  PROV_VERIFY="$(find /usr/local/sbin "$BOOTKIT_ROOT/bootkit/bin" -name aevum-provenance-verify -type f 2>/dev/null | head -1 || echo "")"
fi
if [ -n "$PROV_VERIFY" ]; then
  if ! "$PROV_VERIFY" --bundle-dir "$CUR_BUNDLE" --mode "$MODE"; then
    echo "ERROR: Provenance verification failed. Refusing to apply."
    exit 11
  fi
  echo "[provenance] Supply-chain verification passed."
else
  if [ "$MODE" = "locked" ]; then
    echo "ERROR: aevum-provenance-verify not found; mode is locked. Refusing to apply."
    exit 12
  fi
  echo "[warn] aevum-provenance-verify not found; skipping (mode=$MODE)."
fi

echo "[apply] 1/3 bootkit..."
if [ -x "$BOOTKIT_ROOT/bootkit/install_bootkit.sh" ]; then
  sudo "$BOOTKIT_ROOT/bootkit/install_bootkit.sh" --mode "$MODE"
else
  echo "[warn] bootkit install script not present; skipping."
fi

echo "[apply] 2/3 bootstrap..."
if [ -x "$CURRENT/pack/bin/aevum-workstation-apply" ]; then
  sudo AEVUM_MODE="$MODE" AEVUM_FIREWALL_MODE="$FWMODE" "$CURRENT/pack/bin/aevum-workstation-apply"
else
  echo "ERROR: bootstrap apply script not found in $CURRENT/pack/bin"
  exit 10
fi

echo "[apply] 3/3 gitops..."
if [ -x "$GITOPS_ROOT/gitops/install_workstation_gitops.sh" ]; then
  sudo AEVUM_MODE="$MODE" "$GITOPS_ROOT/gitops/install_workstation_gitops.sh"
else
  echo "[warn] gitops install script not present; skipping."
fi

echo "== DONE =="
